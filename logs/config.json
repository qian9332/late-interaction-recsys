{
  "model": {
    "embedding_dim": 64,
    "hidden_dim": 256,
    "num_cross_layers": 3,
    "num_deep_layers": 3,
    "num_attention_heads": 4,
    "dropout": 0.2,
    "temperature_init": 0.07,
    "temperature_min": 0.01,
    "temperature_max": 1.0,
    "late_interaction_topk": 200,
    "num_cross_attention_layers": 2
  },
  "data": {
    "data_dir": "data/ml-25m",
    "min_user_interactions": 50,
    "min_item_interactions": 50,
    "train_ratio": 0.8,
    "time_series_split": true,
    "num_negatives": 4,
    "batch_size": 512,
    "num_workers": 0,
    "sample_ratio": 0.1
  },
  "training": {
    "learning_rate": 0.001,
    "weight_decay": 1e-05,
    "num_epochs": 20,
    "early_stopping_patience": 3,
    "early_stopping_min_delta": 0.0001,
    "max_grad_norm": 1.0,
    "lr_scheduler": "cosine",
    "warmup_epochs": 1,
    "use_amp": false,
    "gradient_accumulation_steps": 1,
    "log_interval": 100,
    "eval_interval": 1,
    "save_interval": 1
  },
  "eval": {
    "recall_k": [
      10,
      50,
      100,
      200
    ],
    "ndcg_k": [
      10,
      50,
      100
    ],
    "mrr_k": [
      10,
      50,
      100
    ],
    "eval_batch_size": 256,
    "faiss_index_type": "IVFFlat",
    "faiss_nlist": 100,
    "faiss_nprobe": 10
  }
}